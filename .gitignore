# ── 敏感配置（含 API Key / Token / Cookie / 业务房间号） ──
.env
ui_config.json
cookies.txt
config.json
profiles.json

# ── 多账号浏览器数据目录（自动生成，含登录态） ──
browser_data/
browser_data_*/
accounts/
logs/

# ── AI 工具自动生成的上下文文件 ──
.codewhale/

# ── Python ──
__pycache__/
*.pyc
*.pyo

# ── 临时调试脚本(不入库,保留在工作区便于复测) ──
_test_*.py

# ── 运行产物 ──
screenshots/
record_data/
danmaku_data/
.stop_flag

# ── 打包产物 ──
dist/
build/
output/
*.spec

# ── IDE ──
.idea/
.vscode/
*.swp
*.swo
