# ═══════════════════════════════════════════════════
# 大明宝钞钱妈妈 · 抖音直播间互动系统
# 环境变量配置文件
# ═══════════════════════════════════════════════════

# ── 火山引擎 ASR（语音识别） ────────────────────
# 获取凭据: https://console.volcengine.com/ → 语音技术 → 大模型语音识别
VOLC_APP_ID=your_app_id_here
VOLC_ACCESS_TOKEN=your_access_token_here
VOLC_RESOURCE_ID=volc.seedasr.sauc.duration

# ── LLM 智能决策引擎 ────────────────────────────
# 支持: openai (DeepSeek/豆包/百炼) / ollama (本地)
LLM_PROVIDER=openai
LLM_MODEL=deepseek-chat
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.deepseek.com

# Ollama 本地模型地址（LLM_PROVIDER=ollama 时使用）
# OLLAMA_URL=http://localhost:11434

# ── 角色轮换间隔（秒） ────────────────────────────
PERSONA_ROTATE_INTERVAL=300

# ── 弹幕发送设置 ─────────────────────────────────
# 发送间隔(秒) / 冷却基准(秒) / 随机抖动(±秒)
SEND_INTERVAL=6
COOLDOWN_BASE=6.0
JITTER=1.5

# ── 知识库规则（可选） ────────────────────────────
# 规则优先从 rules.json 加载，此处为兜底
# KEYWORDS=扣1,统计人数,想看的扣1
# REPLY_TEXT=1111111
